    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\nconst firstResult = response.results?.[0];\n\nif (!firstResult) {\n  throw new Error('No results found in Crawl4AI response');\n}\n\n// Extract the raw_markdown field\nconst markdownObj = firstResult.markdown || {};\nconst markdown = markdownObj.raw_markdown || '';\n\nconst sourceUrl = firstResult.url || '';\nconst success = firstResult.success || false;\n\n// Clean excessive whitespace\nconst cleanedMarkdown = markdown\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .replace(/[ \\t]+/g, ' ')\n  .trim();\n\n// Calculate metrics\nconst wordCount = cleanedMarkdown.split(/\\s+/).filter(w => w.length > 0).length;\nconst fileSizeKb = Math.round(cleanedMarkdown.length / 1024);\n\n// Return with proper pairedItem for n8n\nreturn {\n  json: {\n    source_url: sourceUrl,\n    document: cleanedMarkdown,\n    success: success,\n    word_count: wordCount,\n    file_size_kb: fileSizeKb,\n    crawled_at: new Date().toISOString()\n  },\n  pairedItem: $input.item.pairedItem || { item: 0 }\n};\n"
      },
