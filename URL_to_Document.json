      "parameters": {
        "jsCode": "// Get Agent X output\nconst agentOutput = $input.first().json;\n\n// Parse the output field - handle markdown code blocks\nlet metadata;\nif (typeof agentOutput.output === 'string') {\n  let cleaned = agentOutput.output.trim();\n  \n  // Remove code block markers using character code for backtick (96)\n  const backtick = String.fromCharCode(96);\n  const codeBlockStart = backtick + backtick + backtick + 'json';\n  const codeBlockEnd = backtick + backtick + backtick;\n  \n  cleaned = cleaned.split(codeBlockStart).join('');\n  cleaned = cleaned.split(codeBlockEnd).join('');\n  cleaned = cleaned.trim();\n  \n  metadata = JSON.parse(cleaned);\n} else {\n  metadata = agentOutput.output;\n}\n\n// Get the document ID from earlier in workflow\nconst documentId = $('Edit Fields').first().json.id;\n\n// Return formatted for Supabase\nreturn {\n  json: {\n    id: documentId,\n    title: metadata.title,\n    summary: metadata.summary,\n    key_terms: metadata.key_terms,\n    effective_date: metadata.effective_date\n  }\n};\n"
