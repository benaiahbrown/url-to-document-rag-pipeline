    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH duplicate_analysis AS (\n  SELECT \n    source_url,\n    COUNT(*) as duplicate_count,\n    array_agg(id ORDER BY created_at DESC) as all_ids,\n    MIN(created_at) as oldest,\n    MAX(created_at) as newest,\n    (array_agg(id ORDER BY created_at ASC))[1] as id_to_keep\n  FROM rag_update_queue\n  GROUP BY source_url\n  HAVING COUNT(*) > 1\n),\ndeleted_records AS (\n  DELETE FROM rag_update_queue\n  WHERE id IN (\n    SELECT unnest(all_ids)\n    FROM duplicate_analysis da\n    WHERE id != id_to_keep\n  )\n  RETURNING id, source_url, created_at\n)\nSELECT \n  da.source_url,\n  da.duplicate_count,\n  da.all_ids,\n  da.oldest,\n  da.newest,\n  (da.duplicate_count - 1) as records_deleted,\n  da.id_to_keep as record_kept\nFROM duplicate_analysis da\nORDER BY da.duplicate_count DESC;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
